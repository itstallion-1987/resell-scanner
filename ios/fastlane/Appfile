# Все значения берутся из переменных окружения (GitHub Secrets) — ничего не хардкодим.
# Заполняются ОДИН РАЗ после регистрации Apple Developer (см. docs/release-pipeline.md).
app_identifier(ENV["APP_IDENTIFIER"])          # напр. com.yourname.resellscanner
apple_id(ENV["APPLE_ID"])                       # email Apple ID (только для справки)
team_id(ENV["DEVELOPER_TEAM_ID"])               # Team ID из developer.apple.com (10 символов)
itc_team_id(ENV["ASC_TEAM_ID"])                 # Team ID из App Store Connect (может совпадать)
