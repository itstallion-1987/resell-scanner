default_platform(:ios)

# Релизный пайплайн для Windows-разработчика без личного Mac: всё гоняется на
# macOS-раннере GitHub Actions. Генерация .xcodeproj (xcodegen) — шаг workflow
# ДО fastlane (см. .github/workflows/release.yml), поэтому здесь её нет.
# Разовая настройка и список секретов — docs/release-pipeline.md.

platform :ios do
  # Авторизация к Apple по App Store Connect API key (без 2FA в CI)
  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8"),     # .p8, base64-кодированный
      is_key_content_base64: true,
      in_house: false
    )
  end

  desc "Создать сертификат подписи и профиль (запустить РАЗ при первом релизе)"
  lane :certs do
    match(type: "appstore", readonly: false, api_key: asc_api_key)
  end

  desc "Собрать подписанный релиз и залить в TestFlight"
  lane :release do
    api_key = asc_api_key
    app_id = ENV.fetch("APP_IDENTIFIER")

    # Сертификаты/профили только читаем (созданы ранее лейном :certs)
    match(type: "appstore", readonly: true, api_key: api_key)

    # Токен воркера и номер сборки кладём во ВРЕМЕННЫЙ gitignored xcconfig, а не в
    # командную строку xcodebuild: логи Actions публичны (репозиторий публичный),
    # а так значение не попадает в вывод. ENV.fetch валит сборку, если секрета нет —
    # лучше явный сбой, чем .ipa с плейсхолдером-токеном.
    build_no = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    overrides = File.expand_path("../build-overrides.xcconfig", __dir__) # -> ios/build-overrides.xcconfig
    File.write(overrides, <<~XCCONFIG)
      APP_SHARED_TOKEN = #{ENV.fetch("APP_SHARED_TOKEN")}
      CURRENT_PROJECT_VERSION = #{build_no}
    XCCONFIG

    build_app(
      project: "ResellScanner.xcodeproj",   # cwd = ios/ (working-directory в workflow)
      scheme: "ResellScanner",
      export_method: "app-store",
      xcconfig: overrides,
      output_directory: "build",            # -> ios/build/ResellScanner.ipa
      output_name: "ResellScanner.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: { app_id => "match AppStore #{app_id}" }
      },
      xcargs: "-allowProvisioningUpdates CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=#{ENV.fetch('DEVELOPER_TEAM_ID')}"
    )

    upload_to_testflight(api_key: api_key, skip_waiting_for_build_processing: true)
  end
end
